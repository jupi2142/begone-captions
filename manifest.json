{
  "manifest_version": 3,
  "name": "Begone Captions",
  "version": "2.0",
  "description": "Hides post text on X/Twitter video posts behind a click gate.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Begone Captions"
  },
  "content_scripts": [
    {
      "matches": ["*://x.com/*", "*://twitter.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "begone-captions@example.com",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },
  "icons": {
    "32": "icon-32.png",
    "64": "icon-64.png",
    "128": "icon-128.png"
  }
}
